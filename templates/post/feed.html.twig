{% extends 'base.html.twig' %}

{% block title %}Mon Fil d'actualité — Sukigram{% endblock %}

{% block body %}
    <h1>Mon Fil d'actualité 🐾</h1>

    {% if message is defined %}
        <div class="post" style="text-align: center; padding: 40px;">
            <p>{{ message }}</p>
            <a href="{{ path('app_home') }}" class="btn-primary">Découvrir des comptes</a>
        </div>
    {% else %}
        {% for post in posts %}
            
            {% include 'post/_post_card.html.twig' with {'post': post} %}
        {% endfor %}
    {% endif %}
{% endblock %}