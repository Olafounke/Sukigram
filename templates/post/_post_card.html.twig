{# templates/post/_post_card.html.twig #}
<article class="post" style="background: white; padding: 0; border-radius: 16px; margin-bottom: 30px; box-shadow: var(--shadow); overflow: hidden;">
    
    <div style="padding: 15px; display: flex; justify-content: space-between; align-items: center;">
        <a href="{{ path('app_profile', {username: post.author.username}) }}" style="color: var(--primary-color); font-weight: 800; text-decoration: none;">
            @{{ post.author.username }}
        </a>
        {% if is_granted('POST_DELETE', post) %}
            <a href="{{ path('app_post_delete', {id: post.id}) }}" onclick="return confirm('Supprimer ?')" style="color: var(--error); font-size: 0.8rem; text-decoration: none;">Supprimer</a>
        {% endif %}
    </div>

    {% if post.imageUrl %}
        <img src="{{ asset('uploads/images/' ~ post.imageUrl) }}" alt="Post image" style="width: 100%; display: block; border-top: 1px solid #eee; border-bottom: 1px solid #eee;">
    {% endif %}

    <div style="padding: 15px;">
        <p style="margin-bottom: 15px;"><strong>@{{ post.author.username }}</strong> {{ post.context }}</p>

        <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 15px;">
            <a href="{{ path('app_post_like', {id: post.id}) }}" style="text-decoration: none;">
                {% if app.user and post.likedBy.contains(app.user) %}❤️{% else %}🤍{% endif %}
                <strong>{{ post.likedBy|length }}</strong>
            </a>
            <span style="color: var(--text-muted); font-size: 0.9rem;">💬 {{ post.comments|length }} </span>
        </div>

        {# Section Commentaires #}
        <div class="comments-section" style="border-top: 1px solid #f8fafc; padding-top: 15px;">
            {% for comment in post.comments %}
                <div style="margin-bottom: 10px; font-size: 0.9rem; display: flex; justify-content: space-between; align-items: flex-start;">
                    <div>
                        <strong style="color: var(--primary-dark);">@{{ comment.author.username }}</strong> {{ comment.content }}
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px;">
                            {{ comment.createdAt|date('d M H:i') }}
                            <a href="{{ path('app_comment_like', {id: comment.id}) }}" style="text-decoration: none; margin-left: 10px;">
                                {{ app.user and comment.likedBy.contains(app.user) ? '❤️' : '🤍' }} {{ comment.likedBy|length }}
                            </a>
                        </div>
                    </div>
                    {% if app.user and (comment.author == app.user or post.author == app.user) %}
                        <a href="{{ path('app_comment_delete', {id: comment.id}) }}" onclick="return confirm('Supprimer ce commentaire ?')" style="color: var(--error); font-size: 0.7rem; text-decoration: none;">×</a>
                    {% endif %}
                </div>
            {% endfor %}

            {% if app.user %}
                <form action="{{ path('app_comment_add', {id: post.id}) }}" method="post" style="margin-top: 15px; display: flex; gap: 10px;">
                    <input type="text" name="content" placeholder="Ajouter un commentaire..." required
                           style="flex-grow: 1; border: 1px solid #e2e8f0; border-radius: 20px; padding: 8px 15px; font-size: 0.9rem; outline: none;">
                    <button type="submit" style="background: none; border: none; color: var(--primary-color); font-weight: bold; cursor: pointer;">Publier</button>
                </form>
            {% endif %}
        </div>

        <small style="color: var(--text-muted); margin-top: 15px; display: block;">{{ post.createdAt|date('d M Y') }}</small>
    </div>
</article>