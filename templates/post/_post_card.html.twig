{# templates/post/_post_card.html.twig #}
<article class="post" style="background: white; padding: 25px; border-radius: 16px; margin-bottom: 20px; box-shadow: var(--shadow); border-left: 6px solid var(--primary-light);">
    <div style="margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <a href="{{ path('app_profile', {username: post.author.username}) }}" style="color: var(--primary-color); font-weight: 800; text-decoration: none; font-size: 1.1rem;">
                @{{ post.author.username }}
            </a>
            <small style="color: var(--text-muted); margin-left: 10px;">{{ post.createdAt|date('d M Y à H:i') }}</small>
        </div>
        
    
        {% if is_granted('POST_DELETE', post) %}
            <a href="{{ path('app_post_delete', {id: post.id}) }}" 
               onclick="return confirm('Supprimer ce post ?')" 
               style="color: var(--error); font-size: 0.8rem; text-decoration: none; font-weight: bold;">
               Supprimer
            </a>
        {% endif %}
    </div>

    <p style="font-size: 1.1rem; line-height: 1.5; margin-bottom: 20px; color: var(--text-main);">
        {{ post.context }}
    </p>

    <div style="display: flex; align-items: center; gap: 15px; border-top: 1px solid #f3f4f6; padding-top: 15px;">
        <a href="{{ path('app_post_like', {id: post.id}) }}" style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
            {% if app.user and post.likedBy.contains(app.user) %}
                <span style="font-size: 1.2rem;">❤️</span>
            {% else %}
                <span style="font-size: 1.2rem;">🤍</span>
            {% endif %}
            <strong style="color: var(--text-main); font-size: 1rem;">{{ post.likedBy|length }}</strong>
        </a>
    </div>
</article>